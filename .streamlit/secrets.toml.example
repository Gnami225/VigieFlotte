# Copiez ce fichier en .streamlit/secrets.toml puis renseignez vos valeurs.
# Sur Streamlit Community Cloud : collez ces blocs dans Settings > Secrets.

# --- Base Neon (PostgreSQL) --------------------------------------------------
[neon]
url = "postgresql+psycopg2://UTILISATEUR:MOTDEPASSE@HOTE.neon.tech/NOMBASE?sslmode=require"

# --- Comptes & rôles ---------------------------------------------------------
# Rôles : admin (tout + audit), editeur (édition), lecteur (consultation).
# Les mots de passe peuvent être en clair OU en sha256 (préfixe "sha256:").
# Sans cette section, l'application démarre en mode ouvert (rôle admin).
[auth]
users = '''
[
  {"login": "jacques", "mot_de_passe": "change-moi",        "role": "admin",   "nom": "Jacques K."},
  {"login": "agent",   "mot_de_passe": "change-moi-aussi",  "role": "editeur", "nom": "Agent parc"},
  {"login": "invite",  "mot_de_passe": "lecture",           "role": "lecteur", "nom": "Invité"}
]
'''

# --- Alertes e-mail ----------------------------------------------------------
[email]
smtp_host = "smtp.gmail.com"
smtp_port = "587"
smtp_user = "adresse@exemple.com"
smtp_password = "mot_de_passe_application"
email_from = "adresse@exemple.com"
email_to = "responsable1@pwc.ci, responsable2@pwc.ci"
seuil_jours = "60"
